# ══════════════════════════════════════════════════════════════════
# Polymarket Terminal Rust — Environment Configuration
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════════════════

# ── Wallet ────────────────────────────────────────────────────────

# EOA private key (hex, with or without 0x prefix)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Wallet mode:
#   eoa   — EOA holds USDC.e + CTF tokens directly (default)
#   proxy — EOA signs on behalf of a Polymarket Gnosis Safe proxy wallet
# Auto-detected: set to "proxy" when PROXY_WALLET_ADDRESS is present
WALLET_MODE=eoa

# Proxy wallet address (required only when WALLET_MODE=proxy)
# Find it at: polymarket.com → Profile → Deposit → copy the address shown
PROXY_WALLET_ADDRESS=

# ── Polymarket API credentials ────────────────────────────────────
# Leave blank to auto-derive on first run from PRIVATE_KEY (L1 auth)
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# ── Endpoints (defaults work for mainnet) ─────────────────────────
CLOB_HOST=https://clob.polymarket.com
GAMMA_HOST=https://gamma-api.polymarket.com
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com

# ── Assets & Market Selection ─────────────────────────────────────

# Comma-separated list of assets to trade
# Supported: btc, eth, sol, xrp (and other Chainlink-supported symbols)
MAKER_MM_ASSETS=btc

# Market slot duration to target: "5m" or "15m"
MAKER_MM_DURATION=15m

# ── Maker MM Strategy Settings ────────────────────────────────────

# Shares per side per cycle (minimum 5 — CLOB enforces this)
MAKER_MM_TRADE_SIZE=5

# Maximum combined bid (YES_bid + NO_bid) allowed to enter
# Spread profit = 1.00 - MAX_COMBINED per share pair when both fill
# Example: 0.98 → $0.02 profit per share pair
MAKER_MM_MAX_COMBINED=0.98

# Seconds before market close to force-exit open positions (cut-loss)
MAKER_MM_CUT_LOSS_TIME=60

# Seconds after market open to allow new entries (entry window)
MAKER_MM_ENTRY_WINDOW=45

# Market detector poll interval (seconds)
MAKER_MM_POLL_INTERVAL=5

# Delay between re-entry cycles within the same market (seconds)
MAKER_MM_REENTRY_DELAY=30

# Allow re-entry after a completed cycle (true/false)
MAKER_MM_REENTRY_ENABLED=true

# Bid price range to qualify for entry (cheap side must be in [MIN, MAX])
MAKER_MM_MIN_PRICE=0.30
MAKER_MM_MAX_PRICE=0.69

# Cancel the cheap side order when the expensive side fills first,
# then hold the expensive position and auto-redeem at resolution
MAKER_MM_CANCEL_CHEAP_ON_EXP_FILL=false

# Orderbook polling interval while waiting for entry conditions (seconds)
MAKER_MM_POLL_SEC=3

# ── Conviction Strategy Settings ──────────────────────────────────
# (used by the `conviction` binary only)

# Same as MAKER_MM_ASSETS — assets to monitor for conviction trades
# MAKER_MM_ASSETS=btc,eth

# Same as MAKER_MM_DURATION — slot duration to watch
# MAKER_MM_DURATION=15m

# UTC time windows when conviction bot is paused (skips markets starting in these windows).
# Format: HH:MM-HH:MM,HH:MM-HH:MM (24h UTC). Leave empty or unset to always run.
# CONVICTION_STOP_WINDOWS=19:40-22:40,03:40-06:10

# ── Simulation ────────────────────────────────────────────────────

# DRY_RUN=true → simulate orders locally, nothing submitted on-chain
DRY_RUN=true

# Starting USDC balance for simulation P&L tracking
SIM_INITIAL_BALANCE=100.0

# ── Logging ───────────────────────────────────────────────────────
# RUST_LOG=info    → strategy events and key actions (recommended)
# RUST_LOG=debug   → verbose: all API calls and WS messages
# RUST_LOG=warn    → minimal: warnings and errors only
RUST_LOG=info
